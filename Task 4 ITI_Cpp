#include <iostream>
    void increment (int *num){
    std::cout << "the number after the increase: " <<(*num)+1 <<"\n";
    }
    void decrement (int *num){
    std::cout << "the number after the decrease:" <<(*num)-1 <<"\n";
    }
    void Reset(int *num){
    *num=0 ;
    std::cout << "reset to 0: " <<*num<<"\n";
    }
    void showNum (int *num){
    std::cout << "the number after the increase: " <<(*num) <<"\n";
    } 
    int main (){
