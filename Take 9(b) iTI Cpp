#include <iostream>
#include <string>
using namespace std;
class Vehicle {
protected:
    string color;
    int speed;
    int model;
    string fuelType;
    string motionStatus;

public:
   Vehicle(string col, int spd, int mod, string fuel, string motion) {
        color = col;
        speed = spd;
        model = mod;
        fuelType = fuel;
        motionStatus = motion;
    }
    ~Vehicle() {
        cout << "Vehicle destructor called.\n";
    }
};
class Car : public Vehicle {
private:
    string brand;
    int doorsCount;

public:
    Car(string brand, int doors, string col, int spd, int mod, string fuel, string motion)
        : Vehicle(col, spd, mod, fuel, motion) {
        this->brand = brand;
        this->doorsCount = doors;
    }

    void printInfo() {
        cout << "--- Car Information ---\n";
        cout << "Brand: " << brand << endl;
        cout << "Doors: " << doorsCount << endl;
        cout << "Color: " << color << endl;
        cout << "Speed: " << speed << " km/h\n";
        cout << "Model: " << model << endl;
        cout << "Fuel Type: " << fuelType << endl;
        cout << "Status: " << motionStatus << endl;
        cout << "-----------------------\n";
    }

    ~Car() {
        cout << "Car destructor called for " << brand << endl;
    }
};
